# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nexst_dev?schema=public"

# JWT
JWT_SECRET="change-me-jwt-secret-min-32-chars-long"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Next Auth
NEXTAUTH_SECRET="change-me-nextauth-secret-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# API
NEXT_PUBLIC_API_URL="http://localhost:3001"
# Internal API URL for server-side requests (Docker: http://api:3001)
API_URL="http://localhost:3001"

# Mailer
# json — dev-режим (письма логируются, реальный SMTP не нужен); smtp — реальная отправка
MAIL_TRANSPORT="json"
MAIL_FROM="no-reply@example.com"
# SMTP_* обязательны только при MAIL_TRANSPORT=smtp
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
# Базовый URL веб-приложения для ссылок в письмах
WEB_URL="http://localhost:3000"
# TTL одноразовых токенов: <число><s|m|h|d|w>
EMAIL_VERIFICATION_TTL="24h"
PASSWORD_RESET_TTL="1h"

# Docker / Production (не нужны для локальной разработки)
POSTGRES_USER="postgres"
POSTGRES_PASSWORD=""
POSTGRES_DB="nexst"
REDIS_PASSWORD=""
